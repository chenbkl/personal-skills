{
  "api": "跨市场比价HAAPI",
  "apiKey": "hk/company/hot/ss_ha",
  "url": "https://open.lixinger.com/api/hk/company/hot/ss_ha",
  "method": "POST",
  "params": [
    {
      "name": "token",
      "required": "Yes",
      "type": "String",
      "descriptions": [
        "我的Token页有用户专属且唯一的Token。"
      ]
    },
    {
      "name": "stockCodes",
      "required": "Yes",
      "type": "Array",
      "descriptions": [
        "股票代码数组。"
      ],
      "constraints": [
        "stockCodes长度>=1且<=100。",
        "请参考股票信息API获取合法的stockCode。"
      ],
      "example": "[\"00700\"]"
    }
  ],
  "responseParams": [
    {
      "name": "stockCode",
      "type": "String",
      "description": "股票代码"
    },
    {
      "name": "last_data_date",
      "type": "Date",
      "description": "数据时间"
    },
    {
      "name": "ss_cdr",
      "type": "Number",
      "description": "最新折价率"
    },
    {
      "name": "ss_dra_w1",
      "type": "Number",
      "description": "过去一个周折价率均值"
    },
    {
      "name": "ss_dra_m1",
      "type": "Number",
      "description": "过去一个月折价率均值"
    },
    {
      "name": "ss_dra_m3",
      "type": "Number",
      "description": "过去三个月折价率均值"
    },
    {
      "name": "ss_dra_m6",
      "type": "Number",
      "description": "过去六个月折价率均值"
    },
    {
      "name": "ss_dra_y1",
      "type": "Number",
      "description": "过去一年折价率均值"
    },
    {
      "name": "ss_dra_y2",
      "type": "Number",
      "description": "过去两年折价率均值"
    },
    {
      "name": "ss_dra_y3",
      "type": "Number",
      "description": "过去三年折价率均值"
    }
  ],
  "requestExample": [
    {
      "desc": "示例1: get by {stockType} codes",
      "requestBody": {
        "stockCodes": [
          "03750"
        ],
        "token": "***********"
      }
    }
  ]
}