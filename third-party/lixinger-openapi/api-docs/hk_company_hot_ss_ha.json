{
  "api": "跨市场比价HAAPI",
  "apiKey": "hk/company/hot/ss_ha",
  "url": "https://open.lixinger.com/api/hk/company/hot/ss_ha",
  "method": "POST",
  "params": [
    {
      "name": "token",
      "required": "Yes",
      "type": "String",
      "descriptions": [
        "我的Token页有用户专属且唯一的Token。"
      ]
    },
    {
      "name": "stockCodes",
      "required": "No",
      "type": "Array",
      "descriptions": [
        "股票代码数组。"
      ],
      "constraints": [
        "stockCodes长度>=1且<=100。",
        "请参考股票信息API获取合法的stockCode。"
      ],
      "example": "[\"00700\"]"
    },
    {
      "name": "sortName",
      "required": "No",
      "type": "String",
      "descriptions": [
        "排序字段。"
      ],
      "constraints": [
        "不提供stockCodes时必填。"
      ]
    },
    {
      "name": "sortOrder",
      "required": "No",
      "type": "String",
      "descriptions": [
        "排序顺序，asc或者desc。"
      ],
      "constraints": [
        "不提供stockCodes时必填。"
      ]
    },
    {
      "name": "pageIndex",
      "required": "No",
      "type": "Number",
      "descriptions": [
        "页码，从0开始。"
      ],
      "constraints": [
        "默认值为 0。必须是大于等于 0 的整数。"
      ]
    },
    {
      "name": "pageSize",
      "required": "No",
      "type": "Number",
      "descriptions": [
        "每页记录数。"
      ],
      "constraints": [
        "取值范围 1 至 100，默认 100。"
      ]
    }
  ],
  "responseParams": [
    {
      "name": "stockCode",
      "type": "String",
      "description": "股票代码"
    },
    {
      "name": "last_data_date",
      "type": "Date",
      "description": "数据时间"
    },
    {
      "name": "ss_cdr",
      "type": "Number",
      "description": "最新折价率"
    },
    {
      "name": "ss_dra_w1",
      "type": "Number",
      "description": "过去一个周折价率均值"
    },
    {
      "name": "ss_dra_m1",
      "type": "Number",
      "description": "过去一个月折价率均值"
    },
    {
      "name": "ss_dra_m3",
      "type": "Number",
      "description": "过去三个月折价率均值"
    },
    {
      "name": "ss_dra_m6",
      "type": "Number",
      "description": "过去六个月折价率均值"
    },
    {
      "name": "ss_dra_y1",
      "type": "Number",
      "description": "过去一年折价率均值"
    },
    {
      "name": "ss_dra_y2",
      "type": "Number",
      "description": "过去两年折价率均值"
    },
    {
      "name": "ss_dra_y3",
      "type": "Number",
      "description": "过去三年折价率均值"
    }
  ],
  "requestExample": [
    {
      "desc": "示例1: 通过公司代码获取",
      "requestBody": {
        "stockCodes": [
          "03750"
        ],
        "token": "***********"
      }
    },
    {
      "desc": "示例2: 通过sortName获取",
      "requestBody": {
        "sortName": "ss_cdr",
        "sortOrder": "desc",
        "pageIndex": 0,
        "pageSize": 50,
        "token": "***********"
      }
    }
  ]
}