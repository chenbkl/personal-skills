{
  "api": "限售解禁API",
  "apiKey": "cn/company/hot/elr",
  "url": "https://open.lixinger.com/api/cn/company/hot/elr",
  "method": "POST",
  "params": [
    {
      "name": "token",
      "required": "Yes",
      "type": "String",
      "descriptions": [
        "我的Token页有用户专属且唯一的Token。"
      ]
    },
    {
      "name": "stockCodes",
      "required": "No",
      "type": "Array",
      "descriptions": [
        "股票代码数组。"
      ],
      "constraints": [
        "stockCodes长度>=1且<=100。",
        "请参考股票信息API获取合法的stockCode。"
      ],
      "example": "[\"300750\",\"600519\",\"600157\"]"
    },
    {
      "name": "sortName",
      "required": "No",
      "type": "String",
      "descriptions": [
        "排序字段。"
      ],
      "constraints": [
        "不提供stockCodes时必填。"
      ]
    },
    {
      "name": "sortOrder",
      "required": "No",
      "type": "String",
      "descriptions": [
        "排序顺序，asc或者desc。"
      ],
      "constraints": [
        "不提供stockCodes时必填。"
      ]
    },
    {
      "name": "pageIndex",
      "required": "No",
      "type": "Number",
      "descriptions": [
        "页码，从0开始。"
      ],
      "constraints": [
        "默认值为 0。必须是大于等于 0 的整数。"
      ]
    },
    {
      "name": "pageSize",
      "required": "No",
      "type": "Number",
      "descriptions": [
        "每页记录数。"
      ],
      "constraints": [
        "取值范围 1 至 100，默认 100。"
      ]
    }
  ],
  "responseParams": [
    {
      "name": "stockCode",
      "type": "String",
      "description": "股票代码"
    },
    {
      "name": "last_data_date",
      "type": "Date",
      "description": "最近一期预计解除限售时间"
    },
    {
      "name": "srl_last",
      "type": "Number",
      "description": "最近预计解除限售股数"
    },
    {
      "name": "srl_cap_r_last",
      "type": "Number",
      "description": "最近预计解除限售股数占总股本比例"
    },
    {
      "name": "elr_s_y1",
      "type": "Number",
      "description": "未来一年预计解除限售股数"
    },
    {
      "name": "elr_s_cap_r_y1",
      "type": "Number",
      "description": "未来一年预计解除限售股数占总股本比例"
    },
    {
      "name": "elr_mc_y1",
      "type": "Number",
      "description": "未来一年预计解除限售市值"
    }
  ],
  "requestExample": [
    {
      "desc": "示例1: 通过公司代码获取",
      "requestBody": {
        "stockCodes": [
          "300750",
          "600519",
          "600157"
        ],
        "token": "***********"
      }
    },
    {
      "desc": "示例2: 通过sortName获取",
      "requestBody": {
        "sortName": "srl_last",
        "sortOrder": "desc",
        "pageIndex": 0,
        "pageSize": 50,
        "token": "***********"
      }
    }
  ]
}