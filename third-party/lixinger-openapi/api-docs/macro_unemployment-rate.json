{
  "api": "失业率",
  "apiKey": "macro/unemployment-rate",
  "url": "https://open.lixinger.com/api/macro/unemployment-rate",
  "method": "POST",
  "params": [
    {
      "name": "token",
      "required": "Yes",
      "type": "String",
      "descriptions": [
        "我的Token页有用户专属且唯一的Token。"
      ]
    },
    {
      "name": "startDate",
      "required": "Yes",
      "type": "String: YYYY-MM-DD(北京时间)",
      "descriptions": [
        "信息起始时间。"
      ],
      "constraints": [
        "开始和结束的时间间隔不超过10年"
      ]
    },
    {
      "name": "endDate",
      "required": "Yes",
      "type": "String: YYYY-MM-DD(北京时间)",
      "descriptions": [
        "信息结束时间。"
      ]
    },
    {
      "name": "limit",
      "required": "No",
      "type": "Number",
      "descriptions": [
        "返回最近数据的数量。"
      ],
      "constraints": [
        "limit仅在请求数据为date range的情况下生效。"
      ]
    },
    {
      "name": "areaCode",
      "required": "Yes",
      "type": "String",
      "descriptions": [
        "地区代码。"
      ],
      "example": "us",
      "items": [
        {
          "label": "美国",
          "value": "us"
        }
      ]
    },
    {
      "name": "metricsList",
      "required": "Yes",
      "type": "Array",
      "descriptions": [
        "指标数组。"
      ],
      "example": "'u_r'",
      "regions": [
        {
          "label": "美国支持:",
          "items": [
            {
              "label": "失业率",
              "value": "u_r",
              "ectByGranularity": [
                {
                  "label": "年",
                  "value": "y",
                  "ectByExpressionCalculateType": [
                    {
                      "label": "累积"
                    },
                    {
                      "label": "累积同比"
                    }
                  ]
                },
                {
                  "label": "月",
                  "value": "m",
                  "ectByExpressionCalculateType": [
                    {
                      "label": "累积"
                    },
                    {
                      "label": "累积同比"
                    },
                    {
                      "label": "TTM"
                    },
                    {
                      "label": "单月"
                    },
                    {
                      "label": "单月环比"
                    }
                  ]
                }
              ]
            }
          ]
        }
      ]
    }
  ],
  "requestExample": [
    {
      "desc": "示例1: 通过时间范围获取",
      "requestBody": {
        "areaCode": "us",
        "startDate": "2016-05-29",
        "endDate": "2026-05-29",
        "metricsList": [
          "y.u_r.t"
        ],
        "token": "***********"
      }
    }
  ]
}