{
  "api": "公告API",
  "apiKey": "cn/company/announcement",
  "url": "https://open.lixinger.com/api/cn/company/announcement",
  "method": "POST",
  "params": [
    {
      "name": "token",
      "required": "Yes",
      "type": "String",
      "descriptions": [
        "我的Token页有用户专属且唯一的Token。"
      ]
    },
    {
      "name": "stockCode",
      "required": "Yes",
      "type": "String",
      "descriptions": [],
      "constraints": [
        "请参考股票信息API获取合法的stockCode。"
      ]
    },
    {
      "name": "startDate",
      "required": "Yes",
      "type": "String: YYYY-MM-DD(北京时间)",
      "descriptions": [
        "信息起始时间。",
        "用于获取一定时间范围内的数据。"
      ],
      "constraints": [
        "开始和结束的时间间隔不超过10年"
      ]
    },
    {
      "name": "endDate",
      "required": "No",
      "type": "String: YYYY-MM-DD(北京时间)",
      "descriptions": [
        "结束信息日期。用于获取时间范围内的数据，默认值为今天结束。"
      ]
    },
    {
      "name": "limit",
      "required": "No",
      "type": "Number",
      "descriptions": [
        "返回最近数据的数量。"
      ]
    }
  ],
  "responseParams": [
    {
      "name": "date",
      "type": "Date",
      "description": "公告日期"
    },
    {
      "name": "linkText",
      "type": "String",
      "description": "链接文本"
    },
    {
      "name": "linkUrl",
      "type": "String",
      "description": "链接地址"
    },
    {
      "name": "linkType",
      "type": "String",
      "description": "链接类型"
    },
    {
      "name": "types",
      "type": "Array",
      "description": "种类",
      "items": [
        {
          "label": "全部",
          "value": "all"
        },
        {
          "label": "财务报表",
          "value": "fs"
        },
        {
          "label": "业绩预告",
          "value": "fsfc"
        },
        {
          "label": "经营数据",
          "value": "o_d"
        },
        {
          "label": "权益分派",
          "value": "eac"
        },
        {
          "label": "董事会",
          "value": "bm"
        },
        {
          "label": "监事会",
          "value": "sm"
        },
        {
          "label": "股东大会",
          "value": "shm"
        },
        {
          "label": "股权激励",
          "value": "so"
        },
        {
          "label": "解禁",
          "value": "ntsu"
        },
        {
          "label": "债券",
          "value": "b"
        },
        {
          "label": "可转换债券",
          "value": "c_b"
        },
        {
          "label": "股权变更",
          "value": "eat"
        },
        {
          "label": "澄清及风险提示",
          "value": "c_rp"
        },
        {
          "label": "投资者关系",
          "value": "irs"
        },
        {
          "label": "问询函",
          "value": "i_l"
        },
        {
          "label": "配股",
          "value": "sa"
        },
        {
          "label": "增发",
          "value": "spo"
        },
        {
          "label": "回购",
          "value": "srp"
        },
        {
          "label": "IPO",
          "value": "ipo"
        },
        {
          "label": "其它",
          "value": "other"
        }
      ]
    }
  ],
  "requestExample": [
    {
      "desc": "示例1: 通过时间范围获取",
      "requestBody": {
        "startDate": "2025-06-05",
        "endDate": "2026-06-05",
        "stockCode": "300750",
        "token": "***********"
      }
    }
  ]
}