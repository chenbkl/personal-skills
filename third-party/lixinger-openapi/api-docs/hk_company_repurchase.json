{
  "api": "回购API",
  "apiKey": "hk/company/repurchase",
  "instruction": "计算股本为总H股",
  "url": "https://open.lixinger.com/api/hk/company/repurchase",
  "method": "POST",
  "params": [
    {
      "name": "token",
      "required": "Yes",
      "type": "String",
      "descriptions": [
        "我的Token页有用户专属且唯一的Token。"
      ]
    },
    {
      "name": "stockCode",
      "required": "Yes",
      "type": "String",
      "descriptions": [],
      "constraints": [
        "请参考股票信息API获取合法的stockCode。"
      ]
    },
    {
      "name": "startDate",
      "required": "Yes",
      "type": "String: YYYY-MM-DD(北京时间)",
      "descriptions": [
        "信息起始时间。",
        "用于获取一定时间范围内的数据。"
      ],
      "constraints": [
        "开始和结束的时间间隔不超过10年"
      ]
    },
    {
      "name": "endDate",
      "required": "No",
      "type": "String: YYYY-MM-DD(北京时间)",
      "descriptions": [
        "结束信息日期。用于获取时间范围内的数据，默认值为今天结束。"
      ]
    },
    {
      "name": "limit",
      "required": "No",
      "type": "Number",
      "descriptions": [
        "返回最近数据的数量。"
      ]
    }
  ],
  "responseParams": [
    {
      "name": "methodOfRepurchase",
      "type": "String",
      "description": "回购方式"
    },
    {
      "name": "highestPrice",
      "type": "Number",
      "description": "最高价"
    },
    {
      "name": "lowestPrice",
      "type": "Number",
      "description": "最低价"
    },
    {
      "name": "avgPrice",
      "type": "Number",
      "description": "成交均价"
    },
    {
      "name": "num",
      "type": "Number",
      "description": "回购股数"
    },
    {
      "name": "totalPaid",
      "type": "Number",
      "description": "总金额"
    },
    {
      "name": "numPurchasedInYearSinceResolution",
      "type": "Number",
      "description": "本年内至今（自决议案通过以来）在交易所购回的股数"
    },
    {
      "name": "ratioPurchasedSinceResolution",
      "type": "Number",
      "description": "自决议通过以来回购股数占通过决议时股本百分比"
    }
  ],
  "requestExample": [
    {
      "desc": "示例1: 通过时间范围获取",
      "requestBody": {
        "startDate": "2025-06-05",
        "endDate": "2026-06-05",
        "stockCode": "00700",
        "token": "***********"
      }
    }
  ]
}