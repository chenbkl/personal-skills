{
  "api": "最新股东API",
  "apiKey": "hk/company/latest-shareholders",
  "url": "https://open.lixinger.com/api/hk/company/latest-shareholders",
  "method": "POST",
  "params": [
    {
      "name": "token",
      "required": "Yes",
      "type": "String",
      "descriptions": [
        "我的Token页有用户专属且唯一的Token。"
      ]
    },
    {
      "name": "stockCode",
      "required": "Yes",
      "type": "String",
      "descriptions": [
        "股票代码"
      ],
      "constraints": [
        "请参考股票信息API获取合法的stockCode。"
      ]
    }
  ],
  "responseParams": [
    {
      "name": "date",
      "type": "Date",
      "description": "最后申报有关通知之日期"
    },
    {
      "name": "name",
      "type": "String",
      "description": "姓名"
    },
    {
      "name": "numOfSharesInterestedList",
      "type": "Array",
      "description": "持有权益的股份数目",
      "items": [
        {
          "label": "数额",
          "value": "value"
        },
        {
          "label": "股份类型",
          "value": "sharesType"
        }
      ]
    },
    {
      "name": "percentageOfIssuedVotingShares",
      "type": "Array",
      "description": "占已发行的有投票权股份百分比",
      "items": [
        {
          "label": "数额",
          "value": "value"
        },
        {
          "label": "股份类型",
          "value": "sharesType"
        }
      ]
    }
  ],
  "requestExample": [
    {
      "desc": "示例1: 通过代码获取",
      "requestBody": {
        "stockCode": "00700",
        "token": "***********"
      }
    }
  ]
}