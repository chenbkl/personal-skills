{
  "api": "分红再投入收益率API",
  "apiKey": "cn/company/hot/tr_dri",
  "instruction": "理杏仁采用分红再投入策略计算投资收益率",
  "url": "https://open.lixinger.com/api/cn/company/hot/tr_dri",
  "method": "POST",
  "params": [
    {
      "name": "token",
      "required": "Yes",
      "type": "String",
      "descriptions": [
        "我的Token页有用户专属且唯一的Token。"
      ]
    },
    {
      "name": "stockCodes",
      "required": "Yes",
      "type": "Array",
      "descriptions": [
        "股票代码数组。"
      ],
      "constraints": [
        "stockCodes长度>=1且<=100。",
        "请参考股票信息API获取合法的stockCode。"
      ],
      "example": "[\"300750\",\"600519\",\"600157\"]"
    }
  ],
  "responseParams": [
    {
      "name": "stockCode",
      "type": "String",
      "description": "股票代码"
    },
    {
      "name": "last_data_date",
      "type": "Date",
      "description": "数据时间"
    },
    {
      "name": "p_r",
      "type": "Number",
      "description": "指定时间段投资收益率"
    },
    {
      "name": "cagr_p_r_fys",
      "type": "Number",
      "description": "今年以来投资收益率"
    },
    {
      "name": "cagr_p_r_d7",
      "type": "Number",
      "description": "近7日投资收益率"
    },
    {
      "name": "cagr_p_r_d14",
      "type": "Number",
      "description": "近14日投资收益率"
    },
    {
      "name": "cagr_p_r_d30",
      "type": "Number",
      "description": "近30日投资收益率"
    },
    {
      "name": "cagr_p_r_d60",
      "type": "Number",
      "description": "近60日投资收益率"
    },
    {
      "name": "cagr_p_r_d90",
      "type": "Number",
      "description": "近90日投资收益率"
    },
    {
      "name": "cagr_p_r_y1",
      "type": "Number",
      "description": "近一年投资收益率"
    },
    {
      "name": "cagr_p_r_y3",
      "type": "Number",
      "description": "近三年年化投资收益率"
    },
    {
      "name": "cagr_p_r_y5",
      "type": "Number",
      "description": "近五年年化投资收益率"
    },
    {
      "name": "cagr_p_r_y10",
      "type": "Number",
      "description": "近十年年化投资收益率"
    },
    {
      "name": "cagr_p_r_y20",
      "type": "Number",
      "description": "近二十年年化投资收益率"
    },
    {
      "name": "cagr_p_r_fs",
      "type": "Number",
      "description": "上市至今年化投资收益率"
    },
    {
      "name": "p_r_fs",
      "type": "Number",
      "description": "上市以来总投资收益率"
    },
    {
      "name": "period_date",
      "type": "Date",
      "description": "投资收益率计算起始日期"
    }
  ],
  "requestExample": [
    {
      "desc": "示例1: get by {stockType} codes",
      "requestBody": {
        "stockCodes": [
          "300750",
          "600519",
          "600157"
        ],
        "token": "***********"
      }
    }
  ]
}