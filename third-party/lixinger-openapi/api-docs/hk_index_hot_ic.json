{
  "api": "样本API",
  "apiKey": "hk/index/hot/ic",
  "url": "https://open.lixinger.com/api/hk/index/hot/ic",
  "method": "POST",
  "params": [
    {
      "name": "token",
      "required": "Yes",
      "type": "String",
      "descriptions": [
        "我的Token页有用户专属且唯一的Token。"
      ]
    },
    {
      "name": "stockCodes",
      "required": "Yes",
      "type": "Array",
      "descriptions": [
        "指数代码数组。"
      ],
      "constraints": [
        "stockCodes长度>=1且<=100。",
        "请参考指数信息API获取合法的stockCode。"
      ],
      "example": "[\"HSI\"]"
    }
  ],
  "responseParams": [
    {
      "name": "stockCode",
      "type": "String",
      "description": "股票代码"
    },
    {
      "name": "last_data_date",
      "type": "Date",
      "description": "数据时间"
    },
    {
      "name": "ic_t10_ws",
      "type": "Number",
      "description": "前十大权重"
    },
    {
      "name": "ic_num",
      "type": "Number",
      "description": "样本数"
    }
  ],
  "requestExample": [
    {
      "desc": "示例1: get by {stockType} codes",
      "requestBody": {
        "stockCodes": [
          "HSI"
        ],
        "token": "***********"
      }
    }
  ]
}