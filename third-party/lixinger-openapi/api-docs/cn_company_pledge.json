{
  "api": "股权质押API",
  "apiKey": "cn/company/pledge",
  "url": "https://open.lixinger.com/api/cn/company/pledge",
  "method": "POST",
  "params": [
    {
      "name": "token",
      "required": "Yes",
      "type": "String",
      "descriptions": [
        "我的Token页有用户专属且唯一的Token。"
      ]
    },
    {
      "name": "stockCode",
      "required": "Yes",
      "type": "String",
      "descriptions": [],
      "constraints": [
        "请参考股票信息API获取合法的stockCode。"
      ]
    },
    {
      "name": "startDate",
      "required": "Yes",
      "type": "String: YYYY-MM-DD(北京时间)",
      "descriptions": [
        "信息起始时间。",
        "用于获取一定时间范围内的数据。"
      ],
      "constraints": [
        "开始和结束的时间间隔不超过10年"
      ]
    },
    {
      "name": "endDate",
      "required": "No",
      "type": "String: YYYY-MM-DD(北京时间)",
      "descriptions": [
        "结束信息日期。用于获取时间范围内的数据，默认值为今天结束。"
      ]
    },
    {
      "name": "limit",
      "required": "No",
      "type": "Number",
      "descriptions": [
        "返回最近数据的数量。"
      ]
    }
  ],
  "responseParams": [
    {
      "name": "date",
      "type": "Date",
      "description": "数据时间"
    },
    {
      "name": "pledgor",
      "type": "String",
      "description": "出质人"
    },
    {
      "name": "pledgee",
      "type": "String",
      "description": "质权人"
    },
    {
      "name": "pledgeMatters",
      "type": "String",
      "description": "质押事项"
    },
    {
      "name": "pledgeSharesNature",
      "type": "String",
      "description": "质押股份性质"
    },
    {
      "name": "pledgeAmount",
      "type": "Number",
      "description": "质押数量"
    },
    {
      "name": "pledgePercentageOfTotalEquity",
      "type": "Number",
      "description": "占总股比例"
    },
    {
      "name": "pledgeStartDate",
      "type": "Date",
      "description": "质押起始日"
    },
    {
      "name": "pledgeEndDate",
      "type": "Date",
      "description": "质押终止日"
    },
    {
      "name": "pledgeDischargeDate",
      "type": "Date",
      "description": "质押解除日"
    },
    {
      "name": "pledgeDischargeExplanation",
      "type": "String",
      "description": "质押解除解释"
    },
    {
      "name": "pledgeDischargeAmount",
      "type": "Number",
      "description": "质押解除数量"
    },
    {
      "name": "isPledgeRepurchaseTransactions",
      "type": "Boolean",
      "description": "是否质押式回购交易"
    },
    {
      "name": "accumulatedPledgePercentageOfTotalEquity",
      "type": "Number",
      "description": "累计质押占总股比例"
    }
  ],
  "requestExample": [
    {
      "desc": "示例1: 通过时间范围获取",
      "requestBody": {
        "startDate": "2025-06-05",
        "endDate": "2026-06-05",
        "stockCode": "300750",
        "token": "***********"
      }
    }
  ]
}