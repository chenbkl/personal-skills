{
  "api": "派息API",
  "apiKey": "hk/company/hot/npd",
  "url": "https://open.lixinger.com/api/hk/company/hot/npd",
  "method": "POST",
  "params": [
    {
      "name": "token",
      "required": "Yes",
      "type": "String",
      "descriptions": [
        "我的Token页有用户专属且唯一的Token。"
      ]
    },
    {
      "name": "stockCodes",
      "required": "Yes",
      "type": "Array",
      "descriptions": [
        "股票代码数组。"
      ],
      "constraints": [
        "stockCodes长度>=1且<=100。",
        "请参考股票信息API获取合法的stockCode。"
      ],
      "example": "[\"00700\"]"
    }
  ],
  "responseParams": [
    {
      "name": "stockCode",
      "type": "String",
      "description": "股票代码"
    },
    {
      "name": "last_data_date",
      "type": "Date",
      "description": "数据时间"
    },
    {
      "name": "tpr_fl",
      "type": "Number",
      "description": "上市以来总派息率"
    },
    {
      "name": "tnp_fl",
      "type": "Number",
      "description": "上市以来总净利润"
    },
    {
      "name": "tda_fl",
      "type": "Number",
      "description": "上市以来总分红"
    }
  ],
  "requestExample": [
    {
      "desc": "示例1: get by {stockType} codes",
      "requestBody": {
        "stockCodes": [
          "00700"
        ],
        "token": "***********"
      }
    }
  ]
}