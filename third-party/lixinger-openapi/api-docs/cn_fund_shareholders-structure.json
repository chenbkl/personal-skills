{
  "api": "持有人结构API",
  "apiKey": "cn/fund/shareholders-structure",
  "url": "https://open.lixinger.com/api/cn/fund/shareholders-structure",
  "method": "POST",
  "params": [
    {
      "name": "token",
      "required": "Yes",
      "type": "String",
      "descriptions": [
        "我的Token页有用户专属且唯一的Token。"
      ]
    },
    {
      "name": "stockCode",
      "required": "Yes",
      "type": "String",
      "descriptions": [],
      "constraints": [
        "请参考基金信息API获取合法的stockCode。"
      ]
    },
    {
      "name": "startDate",
      "required": "Yes",
      "type": "String: YYYY-MM-DD(北京时间)",
      "descriptions": [
        "信息起始时间。",
        "用于获取一定时间范围内的数据。"
      ],
      "constraints": [
        "开始和结束的时间间隔不超过10年"
      ]
    },
    {
      "name": "endDate",
      "required": "No",
      "type": "String: YYYY-MM-DD(北京时间)",
      "descriptions": [
        "结束信息日期。用于获取时间范围内的数据，默认值为今天结束。"
      ]
    },
    {
      "name": "limit",
      "required": "No",
      "type": "Number",
      "descriptions": [
        "返回最近数据的数量。"
      ]
    }
  ],
  "responseParams": [
    {
      "name": "date",
      "type": "Date",
      "description": "数据时间"
    },
    {
      "name": "h_a",
      "type": "Number",
      "description": "持有人户数"
    },
    {
      "name": "h_s_a",
      "type": "Number",
      "description": "持有人平均份额"
    },
    {
      "name": "ins_h_s",
      "type": "Number",
      "description": "机构持有份额"
    },
    {
      "name": "ins_h_s_r",
      "type": "Number",
      "description": "机构投资占比"
    },
    {
      "name": "ind_h_s",
      "type": "Number",
      "description": "个人持有份额"
    },
    {
      "name": "ind_h_s_r",
      "type": "Number",
      "description": "个人持有份额占比"
    },
    {
      "name": "f_f_s",
      "type": "Number",
      "description": "联接基金份额"
    },
    {
      "name": "f_f_s_r",
      "type": "Number",
      "description": "联接基金份额占比"
    }
  ],
  "requestExample": [
    {
      "desc": "示例1: 通过时间范围获取",
      "requestBody": {
        "startDate": "2025-05-29",
        "endDate": "2026-05-29",
        "stockCode": "161725",
        "token": "***********"
      }
    }
  ]
}