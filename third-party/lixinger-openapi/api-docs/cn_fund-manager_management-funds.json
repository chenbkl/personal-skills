{
  "api": "管理的基金信息API",
  "apiKey": "cn/fund-manager/management-funds",
  "url": "https://open.lixinger.com/api/cn/fund-manager/management-funds",
  "method": "POST",
  "params": [
    {
      "name": "token",
      "required": "Yes",
      "type": "String",
      "descriptions": [
        "我的Token页有用户专属且唯一的Token。"
      ]
    },
    {
      "name": "stockCodes",
      "required": "Yes",
      "type": "Array",
      "descriptions": [
        "基金经理代码数组。"
      ],
      "constraints": [
        "stockCodes长度>=1且<=100。",
        "请参考基金信息API获取合法的stockCode。"
      ],
      "example": "[\"8801388323\",\"8801372475\"]"
    }
  ],
  "responseParams": [
    {
      "name": "funds",
      "type": "Array",
      "description": "基金数组。",
      "items": [
        {
          "label": "基金名称",
          "value": "name"
        },
        {
          "label": "基金代码",
          "value": "code"
        },
        {
          "label": "任职日期",
          "value": "appointmentDate"
        },
        {
          "label": "离任日期",
          "value": "departureDate"
        }
      ]
    }
  ],
  "requestExample": [
    {
      "desc": "示例1: 获取指定基金经理信息",
      "requestBody": {
        "stockCodes": [
          "8801388323",
          "8801372475"
        ],
        "token": "***********"
      }
    }
  ]
}