{
  "api": "最新持有人结构信息API",
  "apiKey": "cn/fund/hot/fss",
  "url": "https://open.lixinger.com/api/cn/fund/hot/fss",
  "method": "POST",
  "params": [
    {
      "name": "token",
      "required": "Yes",
      "type": "String",
      "descriptions": [
        "我的Token页有用户专属且唯一的Token。"
      ]
    },
    {
      "name": "stockCodes",
      "required": "Yes",
      "type": "Array",
      "descriptions": [
        "基金代码数组。"
      ],
      "constraints": [
        "stockCodes长度>=1且<=100。",
        "请参考基金信息API获取合法的stockCode。"
      ],
      "example": "[\"161725\",\"005827\"]"
    }
  ],
  "responseParams": [
    {
      "name": "stockCode",
      "type": "String",
      "description": "股票代码"
    },
    {
      "name": "last_data_date",
      "type": "Date",
      "description": "数据时间"
    },
    {
      "name": "f_ins_h_s_r",
      "type": "Number",
      "description": "机构持有份额比例"
    },
    {
      "name": "f_ind_h_s_r",
      "type": "Number",
      "description": "个人持有份额占比"
    },
    {
      "name": "f_h_a",
      "type": "Number",
      "description": "持有人户数"
    },
    {
      "name": "f_ins_h_s_r_c_hy",
      "type": "Number",
      "description": "机构持有份额占比变化(半年)"
    },
    {
      "name": "f_ins_h_s_r_c_1y",
      "type": "Number",
      "description": "机构持有份额占比变化(一年)"
    },
    {
      "name": "f_ind_h_s_r_c_hy",
      "type": "Number",
      "description": "个人持有份额占比变化(半年)"
    },
    {
      "name": "f_ind_h_s_r_c_1y",
      "type": "Number",
      "description": "个人持有份额占比变化(一年)"
    }
  ],
  "requestExample": [
    {
      "desc": "示例1: get by {stockType} codes",
      "requestBody": {
        "stockCodes": [
          "161725",
          "005827"
        ],
        "token": "***********"
      }
    }
  ]
}