{
  "api": "财报数据API",
  "apiKey": "hk/company/fs/bank",
  "url": "https://open.lixinger.com/api/hk/company/fs/bank",
  "method": "POST",
  "params": [
    {
      "name": "token",
      "required": "Yes",
      "type": "String",
      "descriptions": [
        "我的Token页有用户专属且唯一的Token。"
      ]
    },
    {
      "name": "stockCodes",
      "required": "Yes",
      "type": "Array",
      "descriptions": [
        "股票代码数组。"
      ],
      "constraints": [
        "stockCodes长度>=1且<=100。",
        "请参考股票信息API获取合法的stockCode。",
        "需要注意的是，当传入startDate时只能传入一个股票代码。"
      ],
      "example": "[\"01398\"]"
    },
    {
      "name": "date",
      "required": "No",
      "type": "String: latest | YYYY-MM-DD(北京时间)",
      "descriptions": [
        "信息日期。"
      ],
      "constraints": [
        "由于每个季度的最后一天为财报日，请确保传入正确的日期，例如：2017-03-31、2017-06-30、2017-09-30、2017-12-31 或 latest。",
        "其中，传入latest会得到最近1.1年内的最新财报数据。",
        "需要注意的是，startDate和date至少要传一个。"
      ]
    },
    {
      "name": "startDate",
      "required": "No",
      "type": "String: YYYY-MM-DD(北京时间)",
      "descriptions": [
        "信息起始时间。",
        "用于获取一定时间范围内的数据。"
      ],
      "constraints": [
        "开始和结束的时间间隔不超过10年",
        "需要注意的是，startDate和date至少要传一个。"
      ]
    },
    {
      "name": "endDate",
      "required": "No",
      "type": "String: YYYY-MM-DD(北京时间)",
      "descriptions": [
        "信息结束时间。",
        "用于获取一定时间范围内的数据。",
        "默认值是上周一。"
      ],
      "constraints": [
        "需要注意的是，请与startDate一起使用。"
      ]
    },
    {
      "name": "limit",
      "required": "No",
      "type": "Number",
      "descriptions": [
        "返回最近数据的数量。"
      ],
      "constraints": [
        "limit仅在请求数据为date range的情况下生效。"
      ]
    },
    {
      "name": "metricsList",
      "required": "Yes",
      "type": "Array",
      "descriptions": [
        "指标数组。"
      ],
      "constraints": [
        "需要注意的是，当stockCodes长度大于1时最多只能选取48个指标；当stockCodes长度等于1时最多只能获取128 个指标。"
      ],
      "example": "q.ps.toi.t,q.bs.ar.c_y2y",
