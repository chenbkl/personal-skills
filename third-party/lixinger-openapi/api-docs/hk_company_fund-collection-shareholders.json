{
  "api": "内资基金公司持股API",
  "apiKey": "hk/company/fund-collection-shareholders",
  "url": "https://open.lixinger.com/api/hk/company/fund-collection-shareholders",
  "method": "POST",
  "params": [
    {
      "name": "token",
      "required": "Yes",
      "type": "String",
      "descriptions": [
        "我的Token页有用户专属且唯一的Token。"
      ]
    },
    {
      "name": "stockCode",
      "required": "Yes",
      "type": "String",
      "descriptions": [],
      "constraints": [
        "请参考股票信息API获取合法的stockCode。"
      ]
    },
    {
      "name": "startDate",
      "required": "Yes",
      "type": "String: YYYY-MM-DD(北京时间)",
      "descriptions": [
        "信息起始时间。",
        "用于获取一定时间范围内的数据。"
      ],
      "constraints": [
        "开始和结束的时间间隔不超过10年"
      ]
    },
    {
      "name": "endDate",
      "required": "No",
      "type": "String: YYYY-MM-DD(北京时间)",
      "descriptions": [
        "结束信息日期。用于获取时间范围内的数据，默认值为今天结束。"
      ]
    },
    {
      "name": "limit",
      "required": "No",
      "type": "Number",
      "descriptions": [
        "返回最近数据的数量。"
      ]
    }
  ],
  "responseParams": [
    {
      "name": "date",
      "type": "Date",
      "description": "数据时间"
    },
    {
      "name": "name",
      "type": "String",
      "description": "基金公司名称"
    },
    {
      "name": "fundCollectionCode",
      "type": "String",
      "description": "基金公司代码"
    },
    {
      "name": "marketCap",
      "type": "Number",
      "description": "持仓市值"
    },
    {
      "name": "holdings",
      "type": "Number",
      "description": "持仓股数"
    }
  ],
  "requestExample": [
    {
      "desc": "示例1: 通过时间范围获取",
      "requestBody": {
        "startDate": "2025-05-29",
        "endDate": "2026-05-29",
        "stockCode": "00700",
        "token": "***********"
      }
    }
  ]
}