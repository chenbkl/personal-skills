{
  "api": "员工信息API",
  "apiKey": "hk/company/employee",
  "url": "https://open.lixinger.com/api/hk/company/employee",
  "method": "POST",
  "params": [
    {
      "name": "token",
      "required": "Yes",
      "type": "String",
      "descriptions": [
        "我的Token页有用户专属且唯一的Token。"
      ]
    },
    {
      "name": "stockCode",
      "required": "Yes",
      "type": "String",
      "descriptions": [],
      "constraints": [
        "请参考股票信息API获取合法的stockCode。"
      ]
    },
    {
      "name": "startDate",
      "required": "Yes",
      "type": "String: YYYY-MM-DD(北京时间)",
      "descriptions": [
        "信息起始时间。",
        "用于获取一定时间范围内的数据。"
      ],
      "constraints": [
        "开始和结束的时间间隔不超过10年"
      ]
    },
    {
      "name": "endDate",
      "required": "No",
      "type": "String: YYYY-MM-DD(北京时间)",
      "descriptions": [
        "结束信息日期。用于获取时间范围内的数据，默认值为今天结束。"
      ]
    },
    {
      "name": "limit",
      "required": "No",
      "type": "Number",
      "descriptions": [
        "返回最近数据的数量。"
      ]
    }
  ],
  "responseParams": [
    {
      "name": "date",
      "type": "Date",
      "description": "公告日期"
    },
    {
      "name": "dataList",
      "type": "Array",
      "description": "数据列表",
      "items": [
        {
          "label": "项目名称",
          "value": "itemName"
        },
        {
          "label": "父项名称",
          "value": "parentItemName"
        },
        {
          "label": "数据显示类型",
          "value": "displayType"
        },
        {
          "label": "数额",
          "value": "value"
        }
      ]
    }
  ],
  "requestExample": [
    {
      "desc": "示例1: 通过时间范围获取",
      "requestBody": {
        "startDate": "2023-06-05",
        "endDate": "2026-06-05",
        "stockCode": "00700",
        "token": "***********"
      }
    }
  ]
}