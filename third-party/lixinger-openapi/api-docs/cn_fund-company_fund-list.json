{
  "api": "基金列表API",
  "apiKey": "cn/fund-company/fund-list",
  "url": "https://open.lixinger.com/api/cn/fund-company/fund-list",
  "method": "POST",
  "params": [
    {
      "name": "token",
      "required": "Yes",
      "type": "String",
      "descriptions": [
        "我的Token页有用户专属且唯一的Token。"
      ]
    },
    {
      "name": "stockCodes",
      "required": "Yes",
      "type": "Array",
      "descriptions": [
        "基金公司代码数组。"
      ],
      "constraints": [
        "stockCodes长度>=1且<=100。",
        "请参考基金信息API获取合法的stockCode。"
      ],
      "example": "[\"50110000\",\"50030000\"]"
    }
  ],
  "responseParams": [
    {
      "name": "fundCodes",
      "type": "Array",
      "description": "基金代码数组。"
    }
  ],
  "requestExample": [
    {
      "desc": "示例1: 获取基金列表信息",
      "requestBody": {
        "stockCodes": [
          "50110000",
          "50030000"
        ],
        "token": "***********"
      }
    }
  ]
}