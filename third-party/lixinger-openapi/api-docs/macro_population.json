{
  "api": "人口",
  "apiKey": "macro/population",
  "url": "https://open.lixinger.com/api/macro/population",
  "method": "POST",
  "params": [
    {
      "name": "token",
      "required": "Yes",
      "type": "String",
      "descriptions": [
        "我的Token页有用户专属且唯一的Token。"
      ]
    },
    {
      "name": "startDate",
      "required": "Yes",
      "type": "String: YYYY-MM-DD(北京时间)",
      "descriptions": [
        "信息起始时间。"
      ],
      "constraints": [
        "开始和结束的时间间隔不超过10年"
      ]
    },
    {
      "name": "endDate",
      "required": "Yes",
      "type": "String: YYYY-MM-DD(北京时间)",
      "descriptions": [
        "信息结束时间。"
      ]
    },
    {
      "name": "limit",
      "required": "No",
      "type": "Number",
      "descriptions": [
        "返回最近数据的数量。"
      ],
      "constraints": [
        "limit仅在请求数据为date range的情况下生效。"
      ]
    },
    {
      "name": "areaCode",
      "required": "Yes",
      "type": "String",
      "descriptions": [
        "地区代码。"
      ],
      "example": "cn",
      "items": [
        {
          "label": "大陆",
          "value": "cn"
        }
      ]
    },
    {
      "name": "metricsList",
      "required": "Yes",
      "type": "Array",
