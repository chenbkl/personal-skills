{
  "api": "分红再投入收益率API",
  "apiKey": "cn/fund/hot/fp",
  "url": "https://open.lixinger.com/api/cn/fund/hot/fp",
  "method": "POST",
  "params": [
    {
      "name": "token",
      "required": "Yes",
      "type": "String",
      "descriptions": [
        "我的Token页有用户专属且唯一的Token。"
      ]
    },
    {
      "name": "stockCodes",
      "required": "Yes",
      "type": "Array",
      "descriptions": [
        "基金代码数组。"
      ],
      "constraints": [
        "stockCodes长度>=1且<=100。",
        "请参考基金信息API获取合法的stockCode。"
      ],
      "example": "[\"161725\",\"005827\"]"
    }
  ],
  "responseParams": [
    {
      "name": "stockCode",
      "type": "String",
      "description": "股票代码"
    },
    {
      "name": "last_data_date",
      "type": "Date",
      "description": "数据时间"
    },
    {
      "name": "f_p_r",
      "type": "Number",
      "description": "指定时间段投资收益率"
    },
    {
      "name": "f_p_r_fys",
      "type": "Number",
      "description": "今年以来分红再投入收益率"
    },
    {
      "name": "f_p_r_m1",
      "type": "Number",
      "description": "分红再投入收益率(1个月)"
    },
    {
      "name": "f_p_r_m3",
      "type": "Number",
      "description": "分红再投入收益率(3个月)"
    },
    {
      "name": "f_p_r_m6",
      "type": "Number",
      "description": "分红再投入收益率(6个月)"
    },
    {
      "name": "f_p_r_y1",
      "type": "Number",
      "description": "分红再投入收益率(1年)"
    },
    {
      "name": "f_p_r_y2",
      "type": "Number",
      "description": "分红再投入收益率(2年)"
    },
    {
      "name": "f_p_r_y3",
      "type": "Number",
      "description": "分红再投入收益率(3年)"
    },
    {
      "name": "f_p_r_y5",
      "type": "Number",
      "description": "分红再投入收益率(5年)"
    },
    {
      "name": "f_p_r_y10",
      "type": "Number",
      "description": "分红再投入收益率(10年)"
    },
    {
      "name": "f_cagr_p_r_fs",
      "type": "Number",
      "description": "成立以来分红再投入年化收益率"
    }
  ],
  "requestExample": [
    {
      "desc": "示例1: get by {stockType} codes",
      "requestBody": {
        "stockCodes": [
          "161725",
          "005827"
        ],
        "token": "***********"
      }
    }
  ]
}