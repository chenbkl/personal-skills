{
  "api": "人均指标API",
  "apiKey": "cn/company/hot/capita",
  "url": "https://open.lixinger.com/api/cn/company/hot/capita",
  "method": "POST",
  "params": [
    {
      "name": "token",
      "required": "Yes",
      "type": "String",
      "descriptions": [
        "我的Token页有用户专属且唯一的Token。"
      ]
    },
    {
      "name": "stockCodes",
      "required": "Yes",
      "type": "Array",
      "descriptions": [
        "股票代码数组。"
      ],
      "constraints": [
        "stockCodes长度>=1且<=100。",
        "请参考股票信息API获取合法的stockCode。"
      ],
      "example": "[\"300750\",\"600519\",\"600157\"]"
    }
  ],
  "responseParams": [
    {
      "name": "stockCode",
      "type": "String",
      "description": "股票代码"
    },
    {
      "name": "last_data_date",
      "type": "Date",
      "description": "数据时间"
    },
    {
      "name": "stn",
      "type": "Number",
      "description": "员工人数"
    },
    {
      "name": "stn_mc_pc",
      "type": "Number",
      "description": "人均市值"
    },
    {
      "name": "stn_toi_pc",
      "type": "Number",
      "description": "人均营业总收入"
    },
    {
      "name": "stn_np_pc",
      "type": "Number",
      "description": "人均净利润"
    },
    {
      "name": "stn_ncffoa_pc",
      "type": "Number",
      "description": "人均经营活动产生的现金流量净额"
    },
    {
      "name": "stn_rade_pc",
      "type": "Number",
      "description": "人均研发费用"
    },
    {
      "name": "stn_s_pc",
      "type": "Number",
      "description": "人均薪酬"
    }
  ],
  "requestExample": [
    {
      "desc": "示例1: get by {stockType} codes",
      "requestBody": {
        "stockCodes": [
          "300750",
          "600519",
          "600157"
        ],
        "token": "***********"
      }
    }
  ]
}