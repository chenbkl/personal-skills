{
  "api": "利润率API",
  "apiKey": "cn/fund-manager/profit-ratio",
  "url": "https://open.lixinger.com/api/cn/fund-manager/profit-ratio",
  "method": "POST",
  "params": [
    {
      "name": "token",
      "required": "Yes",
      "type": "String",
      "descriptions": [
        "我的Token页有用户专属且唯一的Token。"
      ]
    },
    {
      "name": "stockCode",
      "required": "Yes",
      "type": "String",
      "descriptions": [],
      "constraints": [
        "请参考基金信息API获取合法的stockCode。"
      ]
    },
    {
      "name": "startDate",
      "required": "Yes",
      "type": "String: YYYY-MM-DD(北京时间)",
      "descriptions": [
        "信息起始时间。",
        "用于获取一定时间范围内的数据。"
      ],
      "constraints": [
        "开始和结束的时间间隔不超过10年"
      ]
    },
    {
      "name": "endDate",
      "required": "No",
      "type": "String: YYYY-MM-DD(北京时间)",
      "descriptions": [
        "结束信息日期。用于获取时间范围内的数据，默认值为今天结束。"
      ]
    },
    {
      "name": "limit",
      "required": "No",
      "type": "Number",
      "descriptions": [
        "返回最近数据的数量。"
      ]
    }
  ],
  "responseParams": [
    {
      "name": "date",
      "type": "Date",
      "description": "公告日期"
    },
    {
      "name": "startDate",
      "type": "Date",
      "description": "计算起始日期"
    },
    {
      "name": "value",
      "type": "Number",
      "description": "数额"
    }
  ],
  "requestExample": [
    {
      "desc": "示例1: 通过时间范围获取",
      "requestBody": {
        "startDate": "2025-06-05",
        "endDate": "2026-06-05",
        "stockCode": "8801388323",
        "token": "***********"
      }
    }
  ]
}