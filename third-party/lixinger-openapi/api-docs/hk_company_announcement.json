{
  "api": "公告API",
  "apiKey": "hk/company/announcement",
  "url": "https://open.lixinger.com/api/hk/company/announcement",
  "method": "POST",
  "params": [
    {
      "name": "token",
      "required": "Yes",
      "type": "String",
      "descriptions": [
        "我的Token页有用户专属且唯一的Token。"
      ]
    },
    {
      "name": "stockCode",
      "required": "Yes",
      "type": "String",
      "descriptions": [],
      "constraints": [
        "请参考股票信息API获取合法的stockCode。"
      ]
    },
    {
      "name": "startDate",
      "required": "Yes",
      "type": "String: YYYY-MM-DD(北京时间)",
      "descriptions": [
        "信息起始时间。",
        "用于获取一定时间范围内的数据。"
      ],
      "constraints": [
        "开始和结束的时间间隔不超过10年"
      ]
    },
    {
      "name": "endDate",
      "required": "No",
      "type": "String: YYYY-MM-DD(北京时间)",
      "descriptions": [
        "结束信息日期。用于获取时间范围内的数据，默认值为今天结束。"
      ]
    },
    {
      "name": "limit",
      "required": "No",
      "type": "Number",
      "descriptions": [
        "返回最近数据的数量。"
      ]
    }
  ],
  "responseParams": [
    {
      "name": "date",
      "type": "Date",
      "description": "公告日期"
    },
    {
      "name": "linkText",
      "type": "String",
      "description": "链接文本"
    },
    {
      "name": "linkUrl",
      "type": "String",
      "description": "链接地址"
    },
    {
      "name": "linkType",
      "type": "String",
      "description": "链接类型"
    },
    {
      "name": "types",
      "type": "Array",
      "description": "种类",
      "items": [
        {
          "label": "全部",
          "value": "all"
        },
        {
          "label": "财务报表",
          "value": "fs"
        },
        {
          "label": "配售",
          "value": "spo"
        },
        {
          "label": "供股",
          "value": "sa"
        },
        {
          "label": "回购",
          "value": "srp"
        },
        {
          "label": "会议及表决",
          "value": "m_a_v"
        },
        {
          "label": "翌日披露报表—其他",
          "value": "ndd_r"
        },
        {
          "label": "月报表",
          "value": "mr"
        },
        {
          "label": "IPO",
          "value": "ipo"
        }
      ]
    }
  ],
  "requestExample": [
    {
      "desc": "示例1: 通过时间范围获取",
      "requestBody": {
        "startDate": "2025-06-05",
        "endDate": "2026-06-05",
        "stockCode": "00700",
        "token": "***********"
      }
    }
  ]
}