{
  "api": "监管措施API",
  "apiKey": "cn/company/measures",
  "url": "https://open.lixinger.com/api/cn/company/measures",
  "method": "POST",
  "params": [
    {
      "name": "token",
      "required": "Yes",
      "type": "String",
      "descriptions": [
        "我的Token页有用户专属且唯一的Token。"
      ]
    },
    {
      "name": "stockCode",
      "required": "Yes",
      "type": "String",
      "descriptions": [],
      "constraints": [
        "请参考股票信息API获取合法的stockCode。"
      ]
    },
    {
      "name": "startDate",
      "required": "Yes",
      "type": "String: YYYY-MM-DD(北京时间)",
      "descriptions": [
        "信息起始时间。",
        "用于获取一定时间范围内的数据。"
      ],
      "constraints": [
        "开始和结束的时间间隔不超过10年"
      ]
    },
    {
      "name": "endDate",
      "required": "No",
      "type": "String: YYYY-MM-DD(北京时间)",
      "descriptions": [
        "结束信息日期。用于获取时间范围内的数据，默认值为今天结束。"
      ]
    },
    {
      "name": "limit",
      "required": "No",
      "type": "Number",
      "descriptions": [
        "返回最近数据的数量。"
      ]
    }
  ],
  "responseParams": [
    {
      "name": "date",
      "type": "Date",
      "description": "公告日期"
    },
    {
      "name": "type",
      "type": "String",
      "description": "种类",
      "items": [
        {
          "label": "监管警示",
          "value": "sw"
        },
        {
          "label": "通报批评",
          "value": "bc"
        },
        {
          "label": "公开谴责及认定",
          "value": "pcar"
        },
        {
          "label": "监管工作函",
          "value": "sl"
        }
      ]
    },
    {
      "name": "displayTypeText",
      "type": "String",
      "description": "显示类型文本"
    },
    {
      "name": "linkText",
      "type": "String",
      "description": "链接文本"
    },
    {
      "name": "linkUrl",
      "type": "String",
      "description": "链接地址"
    },
    {
      "name": "linkType",
      "type": "String",
      "description": "链接类型"
    },
    {
      "name": "referent",
      "type": "String",
      "description": "对象"
    }
  ],
  "requestExample": [
    {
      "desc": "示例1: 通过时间范围获取",
      "requestBody": {
        "startDate": "2016-05-29",
        "endDate": "2026-05-29",
        "stockCode": "600866",
        "token": "***********"
      }
    }
  ]
}