{
  "api": "做空API",
  "apiKey": "hk/company/hot/ss",
  "instruction": "计算股本为总H股",
  "url": "https://open.lixinger.com/api/hk/company/hot/ss",
  "method": "POST",
  "params": [
    {
      "name": "token",
      "required": "Yes",
      "type": "String",
      "descriptions": [
        "我的Token页有用户专属且唯一的Token。"
      ]
    },
    {
      "name": "stockCodes",
      "required": "Yes",
      "type": "Array",
      "descriptions": [
        "股票代码数组。"
      ],
      "constraints": [
        "stockCodes长度>=1且<=100。",
        "请参考股票信息API获取合法的stockCode。"
      ],
      "example": "[\"00700\"]"
    }
  ],
  "responseParams": [
    {
      "name": "stockCode",
      "type": "String",
      "description": "股票代码"
    },
    {
      "name": "last_data_date",
      "type": "Date",
      "description": "数据时间"
    },
    {
      "name": "assa",
      "type": "Number",
      "description": "累计做空金额"
    },
    {
      "name": "ass_s",
      "type": "Number",
      "description": "累计做空股数"
    },
    {
      "name": "ass_s_cap_r",
      "type": "Number",
      "description": "累计做空占H股比例"
    },
    {
      "name": "ass_s_cap_rc_w1",
      "type": "Number",
      "description": "过去1周累计做空占H股变化比例"
    },
    {
      "name": "ass_s_cap_rc_w4",
      "type": "Number",
      "description": "过去4周累计做空占H股变化比例"
    },
    {
      "name": "ass_s_cap_rc_w12",
      "type": "Number",
      "description": "过去12周累计做空占H股变化比例"
    },
    {
      "name": "ass_s_cap_rc_w24",
      "type": "Number",
      "description": "过去24周累计做空占H股变化比例"
    }
  ],
  "requestExample": [
    {
      "desc": "示例1: get by {stockType} codes",
      "requestBody": {
        "stockCodes": [
          "00700"
        ],
        "token": "***********"
      }
    }
  ]
}