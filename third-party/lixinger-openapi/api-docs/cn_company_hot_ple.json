{
  "api": "股权质押API",
  "apiKey": "cn/company/hot/ple",
  "url": "https://open.lixinger.com/api/cn/company/hot/ple",
  "method": "POST",
  "params": [
    {
      "name": "token",
      "required": "Yes",
      "type": "String",
      "descriptions": [
        "我的Token页有用户专属且唯一的Token。"
      ]
    },
    {
      "name": "stockCodes",
      "required": "Yes",
      "type": "Array",
      "descriptions": [
        "股票代码数组。"
      ],
      "constraints": [
        "stockCodes长度>=1且<=100。",
        "请参考股票信息API获取合法的stockCode。"
      ],
      "example": "[\"300750\",\"600519\",\"600157\"]"
    }
  ],
  "responseParams": [
    {
      "name": "stockCode",
      "type": "String",
      "description": "股票代码"
    },
    {
      "name": "last_data_date",
      "type": "Date",
      "description": "数据时间"
    },
    {
      "name": "ps_sc_r",
      "type": "Number",
      "description": "股权质押占A股比例"
    },
    {
      "name": "pc",
      "type": "Number",
      "description": "质押笔数"
    },
    {
      "name": "ps",
      "type": "Number",
      "description": "质押股数"
    },
    {
      "name": "ps_mc",
      "type": "Number",
      "description": "质押市值"
    },
    {
      "name": "ps_shbt10sh_r",
      "type": "Number",
      "description": "质押股数与前十大股东持股之比"
    }
  ],
  "requestExample": [
    {
      "desc": "示例1: get by {stockType} codes",
      "requestBody": {
        "stockCodes": [
          "300750",
          "600519",
          "600157"
        ],
        "token": "***********"
      }
    }
  ]
}