{
  "api": "分红融资API",
  "apiKey": "cn/company/hot/df",
  "url": "https://open.lixinger.com/api/cn/company/hot/df",
  "method": "POST",
  "params": [
    {
      "name": "token",
      "required": "Yes",
      "type": "String",
      "descriptions": [
        "我的Token页有用户专属且唯一的Token。"
      ]
    },
    {
      "name": "stockCodes",
      "required": "No",
      "type": "Array",
      "descriptions": [
        "股票代码数组。"
      ],
      "constraints": [
        "stockCodes长度>=1且<=100。",
        "请参考股票信息API获取合法的stockCode。"
      ],
      "example": "[\"300750\",\"600519\",\"600157\"]"
    },
    {
      "name": "sortName",
      "required": "No",
      "type": "String",
      "descriptions": [
        "排序字段。"
      ],
      "constraints": [
        "不提供stockCodes时必填。"
      ]
    },
    {
      "name": "sortOrder",
      "required": "No",
      "type": "String",
      "descriptions": [
        "排序顺序，asc或者desc。"
      ],
      "constraints": [
        "不提供stockCodes时必填。"
      ]
    },
    {
      "name": "pageIndex",
      "required": "No",
      "type": "Number",
      "descriptions": [
        "页码，从0开始。"
      ],
      "constraints": [
        "默认值为 0。必须是大于等于 0 的整数。"
      ]
    },
    {
      "name": "pageSize",
      "required": "No",
      "type": "Number",
      "descriptions": [
        "每页记录数。"
      ],
      "constraints": [
        "取值范围 1 至 100，默认 100。"
      ]
    }
  ],
  "responseParams": [
    {
      "name": "stockCode",
      "type": "String",
      "description": "股票代码"
    },
    {
      "name": "dfr_fs",
      "type": "Number",
      "description": "上市以来A股总分红融资比"
    },
    {
      "name": "da_fs",
      "type": "Number",
      "description": "上市以来A股总分红"
    },
    {
      "name": "fa_fs",
      "type": "Number",
      "description": "上市以来A股总融资"
    },
    {
      "name": "financingFlag",
      "type": "Number",
      "description": "上市后是否有股权激励外的融资"
    }
  ],
  "requestExample": [
    {
      "desc": "示例1: 通过公司代码获取",
      "requestBody": {
        "stockCodes": [
          "300750",
          "600519",
          "600157"
        ],
        "token": "***********"
      }
    },
    {
      "desc": "示例2: 通过sortName获取",
      "requestBody": {
        "sortName": "dfr_fs",
        "sortOrder": "desc",
        "pageIndex": 0,
        "pageSize": 50,
        "token": "***********"
      }
    }
  ]
}