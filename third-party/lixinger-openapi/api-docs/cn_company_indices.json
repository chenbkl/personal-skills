{
  "api": "股票所属指数信息API",
  "apiKey": "cn/company/indices",
  "url": "https://open.lixinger.com/api/cn/company/indices",
  "method": "POST",
  "params": [
    {
      "name": "token",
      "required": "Yes",
      "type": "String",
      "descriptions": [
        "我的Token页有用户专属且唯一的Token。"
      ]
    },
    {
      "name": "stockCode",
      "required": "Yes",
      "type": "String",
      "descriptions": [
        "股票代码"
      ],
      "constraints": [
        "请参考股票信息API获取合法的stockCode。"
      ]
    },
    {
      "name": "date",
      "required": "No",
      "type": "String: YYYY-MM-DD(北京时间)",
      "descriptions": [
        "信息时间。默认值是当前最新时间。"
      ]
    }
  ],
  "responseParams": [
    {
      "name": "name",
      "type": "String",
      "description": "指数名称"
    },
    {
      "name": "areaCode",
      "type": "String",
      "description": "地区代码"
    },
    {
      "name": "stockCode",
      "type": "String",
      "description": "指数代码"
    },
    {
      "name": "source",
      "type": "String",
      "description": "指数来源",
      "items": [
        {
          "label": "国证",
          "value": "cni"
        },
        {
          "label": "中证",
          "value": "csi"
        },
        {
          "label": "恒生",
          "value": "hsi"
        },
        {
          "label": "理杏仁",
          "value": "lxri"
        }
      ]
    }
  ],
  "requestExample": [
    {
      "desc": "示例1: 获取最新时间股票所属指数信息",
      "requestBody": {
        "stockCode": "300750",
        "token": "***********"
      }
    },
    {
      "desc": "示例2: 获取指定日期股票所属指数信息",
      "requestBody": {
        "date": "2026-05-29",
        "stockCode": "300750",
        "token": "***********"
      }
    }
  ]
}