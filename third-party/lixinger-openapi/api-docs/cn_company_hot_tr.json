{
  "api": "换手率API",
  "apiKey": "cn/company/hot/tr",
  "url": "https://open.lixinger.com/api/cn/company/hot/tr",
  "method": "POST",
  "params": [
    {
      "name": "token",
      "required": "Yes",
      "type": "String",
      "descriptions": [
        "我的Token页有用户专属且唯一的Token。"
      ]
    },
    {
      "name": "stockCodes",
      "required": "Yes",
      "type": "Array",
      "descriptions": [
        "股票代码数组。"
      ],
      "constraints": [
        "stockCodes长度>=1且<=100。",
        "请参考股票信息API获取合法的stockCode。"
      ],
      "example": "[\"300750\",\"600519\",\"600157\"]"
    }
  ],
  "responseParams": [
    {
      "name": "stockCode",
      "type": "String",
      "description": "股票代码"
    },
    {
      "name": "last_data_date",
      "type": "Date",
      "description": "数据时间"
    },
    {
      "name": "spc",
      "type": "Number",
      "description": "涨跌幅"
    },
    {
      "name": "ta",
      "type": "Number",
      "description": "成交金额"
    },
    {
      "name": "tr_d1",
      "type": "Number",
      "description": "过去1个交易日换手率"
    },
    {
      "name": "tr_d5",
      "type": "Number",
      "description": "过去5个交易日换手率"
    },
    {
      "name": "tr_d10",
      "type": "Number",
      "description": "过去10个交易日换手率"
    },
    {
      "name": "tr_d20",
      "type": "Number",
      "description": "过去20个交易日换手率"
    },
    {
      "name": "tr_d60",
      "type": "Number",
      "description": "过去60个交易日换手率"
    },
    {
      "name": "tr_d120",
      "type": "Number",
      "description": "过去120个交易日换手率"
    },
    {
      "name": "tr_d240",
      "type": "Number",
      "description": "过去240个交易日换手率"
    }
  ],
  "requestExample": [
    {
      "desc": "示例1: get by {stockType} codes",
      "requestBody": {
        "stockCodes": [
          "300750",
          "600519",
          "600157"
        ],
        "token": "***********"
      }
    }
  ]
}