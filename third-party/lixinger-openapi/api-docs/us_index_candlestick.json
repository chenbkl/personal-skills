{
  "api": "K线数据API",
  "apiKey": "us/index/candlestick",
  "instruction": "中证指数全收益率2016年以前没有数据。",
  "url": "https://open.lixinger.com/api/us/index/candlestick",
  "method": "POST",
  "params": [
    {
      "name": "token",
      "required": "Yes",
      "type": "String",
      "descriptions": [
        "我的Token页有用户专属且唯一的Token。"
      ]
    },
    {
      "name": "stockCode",
      "required": "Yes",
      "type": "String",
      "descriptions": [],
      "constraints": [
        "请参考指数信息API获取合法的stockCode。"
      ]
    },
    {
      "name": "type",
      "required": "Yes",
      "type": "String",
      "descriptions": [
        "收盘点位类型。"
      ],
      "example": "normal",
      "items": [
        {
          "label": "正常点位",
          "value": "normal"
        },
        {
          "label": "全收益率点位",
          "value": "total_return"
        }
      ]
    },
    {
      "name": "startDate",
      "required": "Yes",
      "type": "String: YYYY-MM-DD(北京时间)",
      "descriptions": [
        "信息起始时间。",
        "用于获取一定时间范围内的数据。"
      ],
      "constraints": [
        "开始和结束的时间间隔不超过10年"
      ]
    },
    {
      "name": "endDate",
      "required": "No",
      "type": "String: YYYY-MM-DD(北京时间)",
      "descriptions": [
        "结束信息日期。用于获取时间范围内的数据，默认值为今天结束。"
      ]
    },
    {
      "name": "limit",
      "required": "No",
      "type": "Number",
      "descriptions": [
        "返回最近数据的数量。"
      ]
    }
  ],
  "responseParams": [
    {
      "name": "date",
      "type": "Date",
      "description": "数据时间"
    },
    {
      "name": "open",
      "type": "Number",
      "description": "开盘价"
    },
    {
      "name": "close",
      "type": "Number",
      "description": "收盘价"
    },
    {
      "name": "high",
      "type": "Number",
      "description": "最高价"
    },
    {
      "name": "low",
      "type": "Number",
      "description": "最低价"
    },
    {
      "name": "volume",
      "type": "Number",
      "description": "成交量"
    },
    {
      "name": "amount",
      "type": "Number",
      "description": "金额"
    },
    {
      "name": "change",
      "type": "Number",
      "description": "涨跌幅"
    }
  ],
  "requestExample": [
    {
      "desc": "示例1: 通过时间范围获取",
      "requestBody": {
        "type": "normal",
        "startDate": "2025-05-29",
        "endDate": "2026-05-29",
        "stockCode": ".INX",
        "token": "***********"
      }
    }
  ]
}