{
  "api": "原油",
  "apiKey": "macro/crude-oil",
  "url": "https://open.lixinger.com/api/macro/crude-oil",
  "method": "POST",
  "params": [
    {
      "name": "token",
      "required": "Yes",
      "type": "String",
      "descriptions": [
        "我的Token页有用户专属且唯一的Token。"
      ]
    },
    {
      "name": "startDate",
      "required": "Yes",
      "type": "String: YYYY-MM-DD(北京时间)",
      "descriptions": [
        "信息起始时间。"
      ],
      "constraints": [
        "开始和结束的时间间隔不超过10年"
      ]
    },
    {
      "name": "endDate",
      "required": "Yes",
      "type": "String: YYYY-MM-DD(北京时间)",
      "descriptions": [
        "信息结束时间。"
      ]
    },
    {
      "name": "limit",
      "required": "No",
      "type": "Number",
      "descriptions": [
        "返回最近数据的数量。"
      ],
      "constraints": [
        "limit仅在请求数据为date range的情况下生效。"
      ]
    },
    {
      "name": "areaCode",
      "required": "Yes",
      "type": "String",
      "descriptions": [
        "地区代码。"
      ],
      "example": "us",
      "items": [
        {
          "label": "美国",
          "value": "us"
        }
      ]
    },
    {
      "name": "metricsList",
      "required": "Yes",
      "type": "Array",
      "descriptions": [
        "指标数组。"
      ],
      "example": "'wti_co_sp'",
      "regions": [
        {
          "label": "美国支持:",
          "items": [
            {
              "label": "WTI原油现货价格",
              "value": "wti_co_sp",
              "ectByGranularity": []
            },
            {
              "label": "布伦特原油现货价格",
              "value": "brent_co_sp",
              "ectByGranularity": []
            }
          ]
        }
      ]
    }
  ],
  "requestExample": [
    {
      "desc": "示例1: 通过时间范围获取",
      "requestBody": {
        "areaCode": "us",
        "startDate": "2016-06-05",
        "endDate": "2026-06-05",
        "metricsList": [
          "wti_co_sp"
        ],
        "token": "***********"
      }
    }
  ]
}