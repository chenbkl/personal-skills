{
  "api": "基金回撤API",
  "apiKey": "cn/fund/drawdown",
  "url": "https://open.lixinger.com/api/cn/fund/drawdown",
  "method": "POST",
  "params": [
    {
      "name": "token",
      "required": "Yes",
      "type": "String",
      "descriptions": [
        "我的Token页有用户专属且唯一的Token。"
      ]
    },
    {
      "name": "stockCode",
      "required": "Yes",
      "type": "String",
      "descriptions": [],
      "constraints": [
        "请参考基金信息API获取合法的stockCode。"
      ]
    },
    {
      "name": "startDate",
      "required": "Yes",
      "type": "String: YYYY-MM-DD(北京时间)",
      "descriptions": [
        "信息起始时间。",
        "用于获取一定时间范围内的数据。"
      ],
      "constraints": [
        "开始和结束的时间间隔不超过10年"
      ]
    },
    {
      "name": "endDate",
      "required": "No",
      "type": "String: YYYY-MM-DD(北京时间)",
      "descriptions": [
        "结束信息日期。用于获取时间范围内的数据，默认值为今天结束。"
      ]
    },
    {
      "name": "granularity",
      "required": "Yes",
      "type": "String",
      "descriptions": [
        "回撤时间段。"
      ],
      "example": "y1",
      "items": [
        {
          "label": "月",
          "value": "m"
        },
        {
          "label": "季度",
          "value": "q"
        },
        {
          "label": "半年",
          "value": "hy"
        },
        {
          "label": "1年",
          "value": "y1"
        },
        {
          "label": "3年",
          "value": "y3"
        },
        {
          "label": "5年",
          "value": "y5"
        },
        {
          "label": "10年",
          "value": "y10"
        },
        {
          "label": "上市以来",
          "value": "fs"
        }
      ]
    }
  ],
  "responseParams": [
    {
      "name": "date",
      "type": "Date",
      "description": "数据时间"
    },
    {
      "name": "value",
      "type": "Number",
      "description": "回撤"
    }
  ],
  "requestExample": [
    {
      "desc": "示例1: 通过时间范围获取",
      "requestBody": {
        "startDate": "2023-06-05",
        "endDate": "2026-06-05",
        "granularity": "y1",
        "stockCode": "161725",
        "token": "***********"
      }
    }
  ]
}