{
  "api": "龙虎榜API",
  "apiKey": "cn/company/trading-abnormal",
  "url": "https://open.lixinger.com/api/cn/company/trading-abnormal",
  "method": "POST",
  "params": [
    {
      "name": "token",
      "required": "Yes",
      "type": "String",
      "descriptions": [
        "我的Token页有用户专属且唯一的Token。"
      ]
    },
    {
      "name": "stockCode",
      "required": "No",
      "type": "String",
      "descriptions": [],
      "constraints": [
        "请参考股票信息API获取合法的stockCode。"
      ]
    },
    {
      "name": "startDate",
      "required": "No",
      "type": "String: YYYY-MM-DD(北京时间)",
      "descriptions": [
        "信息起始时间。",
        "用于获取一定时间范围内的数据。"
      ],
      "constraints": [
        "开始和结束的时间间隔不超过10年"
      ]
    },
    {
      "name": "endDate",
      "required": "No",
      "type": "String: YYYY-MM-DD(北京时间)",
      "descriptions": [
        "结束信息日期。用于获取时间范围内的数据，默认值为今天结束。"
      ]
    },
    {
      "name": "limit",
      "required": "No",
      "type": "Number",
      "descriptions": [
        "返回最近数据的数量。"
      ],
      "constraints": [
        "limit仅在请求数据为date range的情况下生效。"
      ]
    }
  ],
  "responseParams": [
    {
      "name": "date",
      "type": "Date",
      "description": "数据时间"
    },
    {
      "name": "reasonForDisclosure",
      "type": "String",
      "description": "披露原因"
    },
    {
      "name": "buyList.$.branchName",
      "type": "String",
      "description": "机构昵称"
    },
    {
      "name": "buyList.$.buyAmount",
      "type": "Number",
      "description": "买入金额"
    },
    {
      "name": "buyList.$.sellAmount",
      "type": "Number",
      "description": "卖出金额"
    },
    {
      "name": "institutionBuyCount",
      "type": "Number",
      "description": "买入机构数"
    },
    {
      "name": "institutionSellCount",
      "type": "Number",
      "description": "卖出机构数"
    },
    {
      "name": "institutionBuyAmount",
      "type": "Number",
      "description": "机构买入金额"
    },
    {
      "name": "institutionSellAmount",
      "type": "Number",
      "description": "机构卖出金额"
    },
    {
      "name": "institutionNetPurchaseAmount",
      "type": "Number",
      "description": "机构净买入金额"
    },
    {
      "name": "totalPurchaseAmount",
      "type": "Number",
      "description": "总买入金额"
    },
    {
      "name": "totalSellAmount",
      "type": "Number",
      "description": "总卖出金额"
    },
    {
      "name": "totalNetPurchaseAmount",
      "type": "Number",
      "description": "总净买入金额"
    },
    {
      "name": "sellList.$.branchName",
      "type": "String",
      "description": "机构昵称"
    },
    {
      "name": "sellList.$.buyAmount",
      "type": "Number",
      "description": "买入金额"
    },
    {
      "name": "sellList.$.sellAmount",
      "type": "Number",
      "description": "卖出金额"
    }
  ],
  "requestExample": [
    {
      "desc": "示例1: 通过日期获取",
      "requestBody": {
        "date": "2026-05-19",
        "token": "***********"
      }
    },
    {
      "desc": "示例2: 通过时间范围获取",
      "requestBody": {
        "startDate": "2025-05-29",
        "endDate": "2026-05-29",
        "stockCode": "300750",
        "token": "***********"
      }
    }
  ]
}