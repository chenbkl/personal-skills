{
  "api": "场内基金认购净流入API",
  "apiKey": "us/index/hot/ifet_sni",
  "url": "https://open.lixinger.com/api/us/index/hot/ifet_sni",
  "method": "POST",
  "params": [
    {
      "name": "token",
      "required": "Yes",
      "type": "String",
      "descriptions": [
        "我的Token页有用户专属且唯一的Token。"
      ]
    },
    {
      "name": "stockCodes",
      "required": "No",
      "type": "Array",
      "descriptions": [
        "指数代码数组。"
      ],
      "constraints": [
        "stockCodes长度>=1且<=100。",
        "请参考指数信息API获取合法的stockCode。"
      ],
      "example": "[\".INX\"]"
    },
    {
      "name": "sortName",
      "required": "No",
      "type": "String",
      "descriptions": [
        "排序字段。"
      ],
      "constraints": [
        "不提供stockCodes时必填。"
      ]
    },
    {
      "name": "sortOrder",
      "required": "No",
      "type": "String",
      "descriptions": [
        "排序顺序，asc或者desc。"
      ],
      "constraints": [
        "不提供stockCodes时必填。"
      ]
    },
    {
      "name": "pageIndex",
      "required": "No",
      "type": "Number",
      "descriptions": [
        "页码，从0开始。"
      ],
      "constraints": [
        "默认值为 0。必须是大于等于 0 的整数。"
      ]
    },
    {
      "name": "pageSize",
      "required": "No",
      "type": "Number",
      "descriptions": [
        "每页记录数。"
      ],
      "constraints": [
        "取值范围 1 至 100，默认 100。"
      ]
    }
  ],
  "responseParams": [
    {
      "name": "stockCode",
      "type": "String",
      "description": "股票代码"
    },
    {
      "name": "last_data_date",
      "type": "Date",
      "description": "数据时间"
    },
    {
      "name": "cpc",
      "type": "Number",
      "description": "涨跌幅"
    },
    {
      "name": "ifet_as",
      "type": "Number",
      "description": "场内基金资产规模"
    },
    {
      "name": "ifet_sni_ytd",
      "type": "Number",
      "description": "过去1天场内基金认购净流入"
    },
    {
      "name": "ifet_sni_w1",
      "type": "Number",
      "description": "过去1周场内基金认购净流入"
    },
    {
      "name": "ifet_sni_w2",
      "type": "Number",
      "description": "过去2周场内基金认购净流入"
    },
    {
      "name": "ifet_ssni_m1",
      "type": "Number",
      "description": "过去1个月场内基金认购净流入"
    },
    {
      "name": "ifet_sni_m3",
      "type": "Number",
      "description": "过去3个月场内基金认购净流入"
    },
    {
      "name": "ifet_sni_m6",
      "type": "Number",
      "description": "过去6个月场内基金认购净流入"
    },
    {
      "name": "ifet_sni_y1",
      "type": "Number",
      "description": "过去1年场内基金认购净流入"
    },
    {
      "name": "ifet_sni_y2",
      "type": "Number",
      "description": "过去2年场内基金认购净流入"
    },
    {
      "name": "ifet_sni_fys",
      "type": "Number",
      "description": "今年以来场内基金认购净流入"
    }
  ],
  "requestExample": [
    {
      "desc": "示例1: 通过指数代码获取",
      "requestBody": {
        "stockCodes": [
          ".INX"
        ],
        "token": "***********"
      }
    },
    {
      "desc": "示例2: 通过sortName获取",
      "requestBody": {
        "sortName": "cpc",
        "sortOrder": "desc",
        "pageIndex": 0,
        "pageSize": 50,
        "token": "***********"
      }
    }
  ]
}