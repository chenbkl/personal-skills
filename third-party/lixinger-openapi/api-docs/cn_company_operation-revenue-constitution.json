{
  "api": "营收构成API",
  "apiKey": "cn/company/operation-revenue-constitution",
  "url": "https://open.lixinger.com/api/cn/company/operation-revenue-constitution",
  "method": "POST",
  "params": [
    {
      "name": "token",
      "required": "Yes",
      "type": "String",
      "descriptions": [
        "我的Token页有用户专属且唯一的Token。"
      ]
    },
    {
      "name": "stockCode",
      "required": "Yes",
      "type": "String",
      "descriptions": [],
      "constraints": [
        "请参考股票信息API获取合法的stockCode。"
      ]
    },
    {
      "name": "startDate",
      "required": "Yes",
      "type": "String: YYYY-MM-DD(北京时间)",
      "descriptions": [
        "信息起始时间。",
        "用于获取一定时间范围内的数据。"
      ],
      "constraints": [
        "开始和结束的时间间隔不超过10年"
      ]
    },
    {
      "name": "endDate",
      "required": "No",
      "type": "String: YYYY-MM-DD(北京时间)",
      "descriptions": [
        "结束信息日期。用于获取时间范围内的数据，默认值为今天结束。"
      ]
    },
    {
      "name": "limit",
      "required": "No",
      "type": "Number",
      "descriptions": [
        "返回最近数据的数量。"
      ]
    }
  ],
  "responseParams": [
    {
      "name": "date",
      "type": "Date",
      "description": "数据时间"
    },
    {
      "name": "declarationDate",
      "type": "Date",
      "description": "公告日期"
    },
    {
      "name": "d_oi",
      "type": "Number",
      "description": "境内收入"
    },
    {
      "name": "d_oc",
      "type": "Number",
      "description": "境内营业成本"
    },
    {
      "name": "d_gp_m",
      "type": "Number",
      "description": "境内毛利率"
    },
    {
      "name": "o_oi",
      "type": "Number",
      "description": "境外收入"
    },
    {
      "name": "o_oc",
      "type": "Number",
      "description": "境外营业成本"
    },
    {
      "name": "o_gp_m",
      "type": "Number",
      "description": "境外毛利率"
    },
    {
      "name": "dataList.$.classifyType",
      "type": "String",
      "description": "分类方式"
    },
    {
      "name": "dataList.$.itemName",
      "type": "String",
      "description": "分类名称"
    },
    {
      "name": "dataList.$.parentItemName",
      "type": "Number",
      "description": "上级项目序号"
    },
    {
      "name": "dataList.$.revenue",
      "type": "Number",
      "description": "收入"
    },
    {
      "name": "dataList.$.revenuePercentage",
      "type": "Number",
      "description": "收入比例"
    },
    {
      "name": "dataList.$.costs",
      "type": "Number",
      "description": "成本"
    },
    {
      "name": "dataList.$.costPercentage",
      "type": "Number",
      "description": "成本比例"
    },
    {
      "name": "dataList.$.grossProfitMargin",
      "type": "Number",
      "description": "毛利率"
    }
  ],
  "requestExample": [
    {
      "desc": "示例1: 通过时间范围获取",
      "requestBody": {
        "startDate": "2025-06-05",
        "endDate": "2026-06-05",
        "stockCode": "300750",
        "token": "***********"
      }
    }
  ]
}