{
  "api": "样本信息API",
  "apiKey": "cn/index/constituents",
  "url": "https://open.lixinger.com/api/cn/index/constituents",
  "method": "POST",
  "params": [
    {
      "name": "token",
      "required": "Yes",
      "type": "String",
      "descriptions": [
        "我的Token页有用户专属且唯一的Token。"
      ]
    },
    {
      "name": "stockCodes",
      "required": "No",
      "type": "Array",
      "descriptions": [
        "指数代码数组。"
      ],
      "constraints": [
        "stockCodes长度>=1且<=100。",
        "请参考指数信息API获取合法的stockCode。"
      ],
      "example": "[\"000016\"]"
    },
    {
      "name": "date",
      "required": "Yes",
      "type": "String: latest | YYYY-MM-DD(北京时间)",
      "descriptions": [
        "信息日期。"
      ]
    }
  ],
  "responseParams": [
    {
      "name": "stockCode",
      "type": "String",
      "description": "指数代码"
    },
    {
      "name": "constituents.$.stockCode",
      "type": "String",
      "description": "样本股票代码"
    },
    {
      "name": "constituents.$.stockName",
      "type": "String",
      "description": "股票名称"
    },
    {
      "name": "constituents.$.areaCode",
      "type": "String",
      "description": "地区代码"
    },
    {
      "name": "constituents.$.market",
      "type": "String",
      "description": "市场"
    }
  ],
  "requestExample": [
    {
      "desc": "示例1: 获取指定样本信息",
      "requestBody": {
        "date": "latest",
        "stockCodes": [
          "000016"
        ],
        "token": "***********"
      }
    }
  ]
}