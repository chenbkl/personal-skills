{
  "api": "股票信息API",
  "apiKey": "hk/industry",
  "url": "https://open.lixinger.com/api/hk/industry",
  "method": "POST",
  "params": [
    {
      "name": "token",
      "required": "Yes",
      "type": "String",
      "descriptions": [
        "我的Token页有用户专属且唯一的Token。"
      ]
    },
    {
      "name": "stockCodes",
      "required": "No",
      "type": "Array",
      "descriptions": [
        "行业代码数组。"
      ],
      "constraints": [
        "stockCodes长度>=1且<=100。",
        "请参考行业信息API获取合法的stockCode。"
      ],
      "example": "[\"H50\",\"H5010\"]"
    },
    {
      "name": "source",
      "required": "Yes",
      "type": "String",
      "descriptions": [
        "行业来。"
      ],
      "example": "hsi",
      "items": [
        {
          "label": "恒生",
          "value": "hsi"
        }
      ]
    },
    {
      "name": "level",
      "required": "No",
      "type": "String",
      "descriptions": [
        "行业分类级别。"
      ],
      "example": "one",
      "items": [
        {
          "label": "一级",
          "value": "one"
        },
        {
          "label": "二级",
          "value": "two"
        },
        {
          "label": "三级",
          "value": "three"
        }
      ]
    }
  ],
  "responseParams": [
    {
      "name": "stockCode",
      "type": "String",
      "description": "行业代码"
    },
    {
      "name": "name",
      "type": "String",
      "description": "行业名称"
    },
    {
      "name": "launchDate",
      "type": "Date",
      "description": "发布时间"
    },
    {
      "name": "areaCode",
      "type": "String",
      "description": "地区代码"
    },
    {
      "name": "market",
      "type": "String",
      "description": "市场"
    },
    {
      "name": "fsTableType",
      "type": "String",
      "description": "财务报表类型",
      "items": [
        {
          "label": "非金融",
          "value": "non_financial"
        },
        {
          "label": "银行",
          "value": "bank"
        },
        {
          "label": "证券",
          "value": "security"
        },
        {
          "label": "保险",
          "value": "insurance"
        },
        {
          "label": "房地产投资信托",
          "value": "reit"
        },
        {
          "label": "其他金融",
          "value": "other_financial"
        },
        {
          "label": "混合",
          "value": "hybrid"
        }
      ]
    },
    {
      "name": "level",
      "type": "String",
      "description": "行业分类等级"
    },
    {
      "name": "source",
      "type": "String",
      "description": "行业来源",
      "items": [
        {
          "label": "恒生",
          "value": "hsi"
        }
      ]
    },
    {
      "name": "currency",
      "type": "String",
      "description": "货币"
    }
  ],
  "requestExample": [
    {
      "desc": "示例1: 获取指定行业信息",
      "requestBody": {
        "stockCodes": [
          "H50"
        ],
        "source": "hsi",
        "token": "***********"
      }
    },
    {
      "desc": "示例2: 获取指定分类级别的所有行业信息",
      "requestBody": {
        "source": "hsi",
        "level": "one",
        "token": "***********"
      }
    }
  ]
}